// 4. Form Submission with Validation
document.getElementById('cateringForm').onsubmit = function(e) {
  e.preventDefault();
  
  const fields = {
    name: document.getElementById('cat-name').value,
    date: document.getElementById('cat-date').value,
    time: document.getElementById('cat-time').value,
    offset: document.getElementById('cat-offset').value,
    amount: document.getElementById('cat-amount').value
  };

  // Check mandatory fields
  if (!fields.name || !fields.date || !fields.time || !fields.offset || !fields.amount) {
    showToast("Please fill all mandatory fields!");
    return;
  }

  const index = parseInt(document.getElementById('edit-index').value);
  const newItem = {
    ...fields,
    email: document.getElementById('cat-email').value,
    mobile: document.getElementById('cat-mobile').value
  };

  if(index === -1) cateringData.unshift(newItem);
  else cateringData[index] = newItem;
  
  renderCateringTable();
  toggleCateringModal(false);
};

