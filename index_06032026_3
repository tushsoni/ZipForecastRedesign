      function updateModalView(viewType) {
        const graphCont = document.getElementById("modalGraphContainer");
        const tableCont = document.getElementById("modalTableContainer");

        // Toggle Button Styles
        ["bar", "pie", "line", "table"].forEach((v) => {
          const btn = document.getElementById(`m-${v}`);
          if (v === viewType) {
            btn.className =
              "flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[13px] font-bold bg-blue-600 text-white shadow-md shadow-blue-200";
          } else {
            btn.className =
              "flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[13px] font-bold text-slate-500 hover:text-slate-800 bg-transparent";
          }
        });

        if (viewType === "table") {
          graphCont.classList.add("hidden");
          tableCont.classList.remove("hidden");
          renderModalTable();
        } else {
          graphCont.classList.remove("hidden");
          tableCont.classList.add("hidden");
