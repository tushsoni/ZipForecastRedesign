        hourlyInterval = val;
        document.getElementById("int-hourly").className =
          val === "hourly"
            ? "px-4 py-1.5 rounded-md transition-all bg-white text-indigo-600 shadow-sm"
            : "px-4 py-1.5 rounded-md transition-all text-slate-500 hover:text-slate-800";
