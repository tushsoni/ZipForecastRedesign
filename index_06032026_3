      function renderModalTable() {
        const tbody = document.getElementById("modalTableBody");
        const thead = document.querySelector("#modalTableContainer thead tr");

        // 1. Handle KPI Tiles (Simple 2-column view: Day and Value)
        if (currentModalContext) {
          // Set headers: Removed Status column
          thead.innerHTML = `
      <th class="p-3 text-slate-500 font-bold uppercase text-[10px] tracking-wider text-center">Day</th>
      <th class="p-3 text-slate-500 font-bold uppercase text-[10px] tracking-wider text-center">Value</th>
    `;

          tbody.innerHTML = currentModalContext.labels
            .map((label, i) => {
              const val = currentModalContext.data[i] || 0;
              return `
        <tr class="hover:bg-slate-50/50 transition-colors">
          <td class="p-3 text-slate-700 text-center font-normal">${label}</td>
          <td class="p-3 font-mono text-slate-900 text-center font-normal">
            ${currentModalContext.prefix}${val.toLocaleString()}
          </td>
        </tr>`;
            })
            .join("");
          return;
        }

        // 2. Handle Charts (Multi-column view for the 4 main graphs)
        if (!modalChartInstance) return;

        const labels = modalChartInstance.data.labels;
        const datasets = modalChartInstance.data.datasets;

        // Headers: Bold and Centered based on datasets
        let headerHtml = `<th class="p-3 text-slate-500 font-bold uppercase text-[10px] tracking-wider text-center">Day</th>`;
        datasets.forEach((ds) => {
          headerHtml += `<th class="p-3 text-slate-500 font-bold uppercase text-[10px] tracking-wider text-center">${ds.label}</th>`;
        });
        thead.innerHTML = headerHtml;

        // Rows: Center aligned, Normal weight
        tbody.innerHTML = labels
          .map((label, i) => {
            let rowHtml = `<tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="p-3 text-slate-700 text-center font-normal">${label}</td>`;

            datasets.forEach((ds) => {
              const val = ds.data[i];
              const displayVal =
                val === null || val === undefined ? "—" : val.toLocaleString();
              const isPercent = ds.label.includes("%") ? "%" : "";

              const modalTitle =
                document.getElementById("modalTitle").innerText;
              const isMoney =
                (modalTitle.includes("Sales") ||
                  modalTitle.includes("Forecast")) &&
                !isPercent &&
                !modalTitle.includes("Hours") &&
                !modalTitle.includes("Accuracy")
                  ? "$"
                  : "";

              rowHtml += `<td class="p-3 font-mono text-slate-900 text-center font-normal">${isMoney}${displayVal}${isPercent}</td>`;
            });

            rowHtml += `</tr>`;
            return rowHtml;
          })
          .join("");
      }

