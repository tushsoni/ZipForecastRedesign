      function renderHourlyTable() {
        const body = document.getElementById("hourly-table-body");
        const head = document.querySelector(".hourly-table-container thead tr");

        head.innerHTML = `
        <th class="pl-6 sticky left-0 bg-[#f8fafc] z-20 text-left">Time</th>
        <th class="text-center">MON</th>
        <th class="text-center">TUE</th>
        <th class="text-center">WED</th>
        <th class="text-center">THU</th>
        <th class="text-center">FRI</th>
        <th class="text-center">SAT</th>
        <th class="text-center">SUN</th>
        <th class="text-center pr-6">Total</th>
    `;

        body.innerHTML = "";
        const step = hourlyInterval === "hourly" ? 60 : 15;
        const totalMinutes = 24 * 60;
        let startTime = 240; // 4:00 AM

        for (let i = 0; i < totalMinutes; i += step) {
          const currentMins = (startTime + i) % (24 * 60);
          const hour = Math.floor(currentMins / 60);
          const mins = currentMins % 60;
          const ampm = hour >= 12 ? "PM" : "AM";
          const displayHour = hour % 12 === 0 ? 12 : hour % 12;
          const timeStr = `${displayHour}:${mins.toString().padStart(2, "0")} ${ampm}`;

          const row = document.createElement("tr");
          row.className = i % (step * 2) === 0 ? "bg-white" : "bg-slate-50/30";

          let rowTotal = 0;
          let cellsHtml = `<td class="pl-6 font-bold text-slate-500 border-r bg-inherit sticky left-0 text-left">${timeStr}</td>`;

          for (let d = 0; d < 7; d++) {
            const baseVal = 30 + Math.floor(Math.random() * 60);
            rowTotal += baseVal; // Calculate initial random sum
            cellsHtml += `
                <td class="border-r">
                    <div class="flex items-center justify-center">
                        <div class="flex items-center w-fit">
                            <span class="text-slate-400 mr-0.5">$</span>
                            <input type="text" value="${baseVal}" class="hourly-cell-input" oninput="updateRowTotal(this)">
                        </div>
                    </div>
                </td>`;
          }

          // Use a specific class 'row-total-display' so we can find it easily later
          cellsHtml += `<td class="text-center pr-6 font-bold text-slate-800 row-total-display">$${rowTotal.toLocaleString()}</td>`;
          row.innerHTML = cellsHtml;
          body.appendChild(row);
        }
      }

      // Add this helper function to handle live updates
      function updateRowTotal(inputElement) {
        const row = inputElement.closest("tr");
        const inputs = row.querySelectorAll(".hourly-cell-input");
        const totalCell = row.querySelector(".row-total-display");

        let sum = 0;
        inputs.forEach((input) => {
          const val = parseFloat(input.value) || 0;
          sum += val;
        });

        totalCell.innerText = `$${sum.toLocaleString()}`;
      }

