      function renderDailyHourlyTable(day) {
        const tbody = document.getElementById("dailyHourlyTableBody");
        tbody.innerHTML = "";

        const step = dailyHourlyInterval === "hourly" ? 60 : 15;
        const totalMinutes = 24 * 60;
