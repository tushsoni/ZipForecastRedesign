      // Auto-update Estimated fields when Time or Date is changed
      function updateEstimatedDateTimes() {
        const dateVal = document.getElementById("cat-date").value;
        const timeVal = document.getElementById("cat-time").value;

        if (dateVal && timeVal) {
          // Parse the event date and time
          const eventDate = new Date(dateVal);
          const [hours, mins] = timeVal.split(":").map(Number);
          let eventTimeInMins = hours * 60 + mins;

          // Calculate End Time = Event Time - 2 hours (Completion Time Offset)
          const completionTimeOffset = 2 * 60; // 2 hours
          let endTimeInMins = eventTimeInMins - completionTimeOffset;
          let endDateOffset = 0;

          // Calculate Start Time = End Time - 4 hours (Prep Time)
          const prepTime = 4 * 60; // 4 hours
          let startTimeInMins = endTimeInMins - prepTime;
          let startDateOffset = 0;

          // Handle negative times (previous day)
          if (startTimeInMins < 0) {
            startTimeInMins += 24 * 60; // Add 24 hours
            startDateOffset = -1; // Previous day
          }

          if (endTimeInMins < 0) {
            endTimeInMins += 24 * 60; // Add 24 hours
            endDateOffset = -1; // Previous day
          }

          // Calculate the actual dates
          const startDate = new Date(eventDate);
          startDate.setDate(startDate.getDate() + startDateOffset);

          const endDate = new Date(eventDate);
          endDate.setDate(endDate.getDate() + endDateOffset);

          // Convert time in minutes to HH:MM format
          const formatTime = (totalMins) => {
            const h = Math.floor(totalMins / 60) % 24;
            const m = totalMins % 60;
            return `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
          };

          // Format date as "MMM DD, YYYY"
          const formatDateReadable = (date) => {
            const options = { month: 'short', day: 'numeric', year: 'numeric' };
            return date.toLocaleDateString('en-US', options);
          };

          // Set start time and date
          document.getElementById("cat-est-start-time").textContent = formatTime(startTimeInMins);
          document.getElementById("cat-est-start-date").textContent = formatDateReadable(startDate);

          // Set end time and date
          document.getElementById("cat-est-end-time").textContent = formatTime(endTimeInMins);
          document.getElementById("cat-est-end-date").textContent = formatDateReadable(endDate);
        } else {
          document.getElementById("cat-est-start-time").textContent = "--:--";
          document.getElementById("cat-est-start-date").textContent = "--";
          document.getElementById("cat-est-end-time").textContent = "--:--";
          document.getElementById("cat-est-end-date").textContent = "--";
        }
      }

      document.getElementById("cat-date").addEventListener("input", updateEstimatedDateTimes);
      document.getElementById("cat-time").addEventListener("input", updateEstimatedDateTimes);

