        let timeIndex = 0;

        for (let i = 0; i < totalMinutes; i += step) {
          const currentMins = (startTime + i) % (24 * 60);
          const hour = Math.floor(currentMins / 60);
          const mins = currentMins % 60;
          const ampm = hour >= 12 ? "PM" : "AM";
          const displayHour = hour % 12 === 0 ? 12 : hour % 12;
          const timeStr = `${displayHour}:${mins.toString().padStart(2, "0")} ${ampm}`;

          const baseVal = 30 + Math.floor(Math.random() * 60);

          const row = document.createElement("tr");
