      function renderChart(id, type = "bar") {
        const ctx = document.getElementById(id).getContext("2d");
        if (charts[id]) charts[id].destroy();

        const configType = type === "area" ? "line" : type;
        const data = JSON.parse(JSON.stringify(chartData[id]));

        if (configType === "bar") {
          data.datasets.forEach((ds) => {
            ds.backgroundColor = ds.borderColor; // solid fill
            ds.borderWidth = 0; // remove outline
            ds.borderRadius = 6; // modern rounded bars
            ds.barThickness = 18; // nice width
          });
        }

        if (type === "area") {
          data.datasets.forEach((ds) => (ds.fill = true));
        } else if (type === "line") {
          data.datasets.forEach((ds) => (ds.fill = false));
        }

        charts[id] = new Chart(ctx, {
          type: configType,
          data: data,
          options: {
