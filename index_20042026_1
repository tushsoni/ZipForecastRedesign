      function renderInlineHourlyTable(day) {
        const tbody = document.getElementById("inlineHourlyTableBody");
        tbody.innerHTML = "";

        const step = inlineHourlyInterval === "hourly" ? 60 : 15;
        const totalMinutes = 24 * 60;
        let startTime = 240; // 4:00 AM
        let timeIndex = 0;

        for (let i = 0; i < totalMinutes; i += step) {
          const currentMins = (startTime + i) % (24 * 60);
          const nextMins = (startTime + i + step) % (24 * 60);
          
          // Format start time
          const hour = Math.floor(currentMins / 60);
          const mins = currentMins % 60;
          const ampm = hour >= 12 ? "p" : "a";
          const displayHour = hour % 12 === 0 ? 12 : hour % 12;
          const timeStr = `${displayHour}:${mins.toString().padStart(2, "0")}${ampm}`;
          
          // Format end time
          const nextHour = Math.floor(nextMins / 60);
          const nextMinsVal = nextMins % 60;
          const nextAmpm = nextHour >= 12 ? "p" : "a";
          const nextDisplayHour = nextHour % 12 === 0 ? 12 : nextHour % 12;
          const nextTimeStr = `${nextDisplayHour}:${nextMinsVal.toString().padStart(2, "0")}${nextAmpm}`;
          
          const rangeStr = `${timeStr}-${nextTimeStr}`;

          const baseVal = 30 + Math.floor(Math.random() * 60);

          const row = document.createElement("tr");
          row.className = i % (step * 2) === 0 ? "bg-white" : "bg-slate-50/30";

          const rowHtml = `
            <td class="pl-6 font-bold text-slate-500 border-r bg-inherit sticky left-0 text-left">${rangeStr}</td>
            <td class="border-r pr-6">
              <div class="flex items-center justify-end">
                <div class="flex items-center w-fit">
                  <span class="text-slate-400 mr-0.5">$</span>
                  <input type="text" value="${baseVal}" class="hourly-cell-input" />
                </div>
              </div>
            </td>
          `;
          row.innerHTML = rowHtml;
          tbody.appendChild(row);
          timeIndex++;
        }
      }

      // TOGGLE MY FORECAST AND INCREASE/DECREASE ROWS
      function toggleMyForecastRows() {
        const toggle = document.getElementById("enableMyForecastToggle");
        const myForecastRow = document.getElementById("myForecastRow");
        const increaseDecreaseRow = document.getElementById("increaseDecreaseRow");
        
        if (toggle.checked) {
          myForecastRow.classList.remove("hidden");
