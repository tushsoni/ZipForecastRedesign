      // Render table data from chart
      function renderInlineTable(chartId) {
        const chartInstance = charts[chartId];
        if (!chartInstance) return;

        const labels = chartInstance.data.labels;
        const datasets = chartInstance.data.datasets;
        const theadElement = document.getElementById(chartId + "-table-head");
        const tbody = document.getElementById(chartId + "-table-body");

        if (!theadElement || !tbody) return;

        const thead = theadElement.querySelector("tr");
        if (!thead) return;

        // Build headers
        let headerHtml =
          '<th class="p-3 text-slate-500 font-bold text-[10px] text-left">Day</th>';
        datasets.forEach((ds) => {
          headerHtml += `<th class="p-3 text-slate-500 font-bold text-[10px] text-center">${ds.label}</th>`;
        });
        thead.innerHTML = headerHtml;

        // Build rows
        tbody.innerHTML = labels
          .map((label, i) => {
            let rowHtml = `<tr class="hover:bg-slate-50 transition-colors">
                    <td class="p-3 text-slate-700 text-left font-normal">${label}</td>`;

            datasets.forEach((ds) => {
              const val = ds.data[i];
              const displayVal =
                val === null || val === undefined ? "—" : val.toLocaleString();

              // Determine if this should have $ or % prefix
              let prefix = "";
              let suffix = "";

              // Check for Labor % metric (values typically under 100)
              if (
                chartId === "projectionChart" &&
                (ds.label === "Scheduled" || ds.label === "Actual") &&
                val < 200
              ) {
                suffix = "%";
              }
              // For projectionChart: only add $ for Sales, not for Transactions or Labor
              else if (chartId === "projectionChart") {
                if (currentProjectionMetric === "sales" && val > 1000) {
                  prefix = "$";
                }
              }
              // For trendChart: only add $ for Sales, not for Transactions
              else if (chartId === "trendChart") {
                if (currentTrendMetric === "sales" && val > 1000) {
                  prefix = "$";
                }
              }

              rowHtml += `<td class="p-3 text-slate-900 text-center font-mono">${prefix}${displayVal}${suffix}</td>`;
            });

            rowHtml += `</tr>`;
            return rowHtml;
          })
          .join("");
      }

