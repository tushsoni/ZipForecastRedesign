      // SWITCH FORECAST TYPE (Sales, Transactions, Forecasted Labor)
      function switchForecastType(type) {
        // Update main forecast cells (AI Forecast, Total)
        const cells = document.querySelectorAll(
          '.forecast-cell:not([id^="cater"])',
        );
        const totalCells = document.querySelectorAll(".forecast-total");

        cells.forEach((cell) => {
          const valueSpan = cell.querySelector(".forecast-value");
          if (!valueSpan) return;

          let displayValue = "";

          if (type === "sales") {
            displayValue = cell.getAttribute("data-sales");
            if (displayValue && !displayValue.startsWith("$")) {
              displayValue =
                "$ " +
                parseFloat(displayValue).toLocaleString("en-US", {
                  minimumFractionDigits: 2,
                  maximumFractionDigits: 2,
                });
            }
          } else if (type === "transactions") {
            displayValue = cell.getAttribute("data-transactions");
          } else if (type === "labor") {
            displayValue = cell.getAttribute("data-labor");
          }

          valueSpan.textContent = displayValue;
