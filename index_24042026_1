        startDate.setDate(today.getDate() - 30);

        const data = [];

        // Generate 20-30 random catering events
        const eventCount = Math.floor(Math.random() * 11) + 20;

        for (let i = 0; i < eventCount; i++) {
          // Random date within the last 30 days
          const randomDaysBack = Math.floor(Math.random() * 30);
          const eventDate = new Date(today);
          eventDate.setDate(today.getDate() - randomDaysBack);

          // Random time between 8 AM and 8 PM
          const hours = Math.floor(Math.random() * 12) + 8;
          const minutes = Math.floor(Math.random() * 60);

          const company = getRandomElement(companyNames);
          const email =
            company.toLowerCase().replace(/\s+/g, "") +
            "@" +
            getRandomElement(domains);
          const phone =
            "555-" + String(Math.floor(Math.random() * 10000)).padStart(4, "0");

