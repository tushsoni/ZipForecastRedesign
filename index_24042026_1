        // For bar charts with mixed types, handle styling
        if (type === "bar") {
          // Determine bar thickness based on number of data points (for 14D, use thinner bars)
          const dataPointCount = data.labels ? data.labels.length : 0;
          const barThickness = dataPointCount === 14 ? 14 : 28;

          // Put bars first, then lines (lines will draw on top)
          const barDatasets = [];
          const lineDatasets = [];

          data.datasets.forEach((ds) => {
            // If this is a line dataset (indicated by type: 'line'), keep line styling
            if (ds.type === "line") {
              ds.fill = false;
              ds.borderWidth = 3;
              ds.tension = 0.45;
              ds.pointRadius = 6;
              ds.pointHoverRadius = 8;
              ds.pointBackgroundColor = ds.borderColor;
              ds.clip = false;
              ds.pointBorderColor = ds.borderColor;
              ds.pointBorderWidth = 1;
              // No backgroundColor for lines
              lineDatasets.push(ds);
            } else {
              // Bar styling
              ds.backgroundColor = ds.backgroundColor || ds.borderColor;
              ds.borderWidth = 0;
              ds.borderRadius = 4;
              ds.barThickness = barThickness;
              barDatasets.push(ds);
            }
          });

          // Put bars first, lines last
          data.datasets = [...barDatasets, ...lineDatasets];
