        ];

        document.getElementById("cateringCalendarMonth").textContent =
          monthNames[cateringCalendarState.currentMonth];
        document.getElementById("cateringCalendarYear").textContent =
          cateringCalendarState.currentYear;

        const firstDay = new Date(
          cateringCalendarState.currentYear,
          cateringCalendarState.currentMonth,
          1,
        ).getDay();
        const daysInMonth = new Date(
          cateringCalendarState.currentYear,
          cateringCalendarState.currentMonth + 1,
          0,
        ).getDate();

        const daysContainer = document.getElementById("cateringCalendarDays");
        daysContainer.innerHTML = "";

        // Empty cells for days before month starts
        for (let i = 0; i < firstDay; i++) {
          const emptyCell = document.createElement("div");
          daysContainer.appendChild(emptyCell);
        }

        // Day cells
        for (let day = 1; day <= daysInMonth; day++) {
          const dayCell = document.createElement("button");
          dayCell.textContent = day;
          dayCell.style.cssText =
            "padding: 6px; border: 1px solid #e2e8f0; border-radius: 4px; cursor: pointer; font-size: 12px; background: white; color: #1e293b; transition: all 0.2s;";
          dayCell.onmouseover = function () {
            this.style.background = "#f1f5f9";
          };
          dayCell.onmouseout = function () {
            this.style.background = "white";
          };
          dayCell.onclick = function (e) {
            e.preventDefault();
            selectCateringDate(day);
          };
          daysContainer.appendChild(dayCell);
        }
