          const parentSpan = cell.querySelector("span.font-medium");
          if (!valueSpan) return;

          let displayValue = "";

          if (type === "sales") {
            displayValue = cell.getAttribute("data-sales");
            if (displayValue && !displayValue.startsWith("$")) {
              displayValue =
                "$ " +
                parseFloat(displayValue).toLocaleString("en-US", {
                  minimumFractionDigits: 2,
                  maximumFractionDigits: 2,
                });
            }
            parentSpan.innerHTML =
