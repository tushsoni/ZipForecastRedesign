        rows.forEach((row) => {
          const cells = row.querySelectorAll("td");
          const rowData = [];
          cells.forEach((cell) => {
            rowData.push(cell.textContent.trim());
          });
          xlsx.push(rowData.join("\t"));
        });

        downloadHourlyFile(xlsx.join("\n"), "hourly_forecast.xlsx");
