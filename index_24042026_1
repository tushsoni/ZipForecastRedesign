      function openHourlyCalendar(field) {
        event?.stopPropagation?.();
        hourlyCalendarState.selectedField = field;

        // Set initial date if one is already selected
        const dateInput =
          field === "start"
            ? document.getElementById("hourlyStartDateInput")
            : document.getElementById("hourlyEndDateInput");

        if (dateInput.value) {
          const dateParts = dateInput.value.split("/");
          hourlyCalendarState.currentMonth = parseInt(dateParts[0]) - 1;
          hourlyCalendarState.currentYear = parseInt(dateParts[2]);
        } else {
          hourlyCalendarState.currentMonth = new Date().getMonth();
          hourlyCalendarState.currentYear = new Date().getFullYear();
        }

        const calendarPopup = document.getElementById("hourlyCalendarPopup");

        if (calendarPopup) {
          calendarPopup.style.display = "block";
          renderHourlyCalendar();
        }
      }

      function closeHourlyCalendar() {
        event?.stopPropagation?.();
        const calendarPopup = document.getElementById("hourlyCalendarPopup");
        if (calendarPopup) {
          calendarPopup.style.display = "none";
        }
      }

      function renderHourlyCalendar() {
        const monthNames = [
          "January",
          "February",
          "March",
          "April",
          "May",
          "June",
          "July",
          "August",
          "September",
          "October",
          "November",
          "December",
        ];

        document.getElementById("hourlyCalendarMonth").textContent =
          monthNames[hourlyCalendarState.currentMonth];
        document.getElementById("hourlyCalendarYear").textContent =
          hourlyCalendarState.currentYear;

        const firstDay = new Date(
          hourlyCalendarState.currentYear,
          hourlyCalendarState.currentMonth,
          1,
        ).getDay();
        const daysInMonth = new Date(
          hourlyCalendarState.currentYear,
          hourlyCalendarState.currentMonth + 1,
          0,
        ).getDate();

        const daysContainer = document.getElementById("hourlyCalendarDays");
        daysContainer.innerHTML = "";

        // Empty cells for days before month starts
        for (let i = 0; i < firstDay; i++) {
          const emptyCell = document.createElement("div");
          daysContainer.appendChild(emptyCell);
        }

        // Day cells
        for (let day = 1; day <= daysInMonth; day++) {
          const dayCell = document.createElement("button");
          dayCell.textContent = day;
          dayCell.style.padding = "6px 4px";
          dayCell.style.border = "1px solid #e2e8f0";
          dayCell.style.borderRadius = "4px";
          dayCell.style.cursor = "pointer";
          dayCell.style.fontSize = "12px";
          dayCell.style.backgroundColor = "#f8fafc";
          dayCell.style.color = "#1e293b";
          dayCell.onclick = () => selectHourlyDate(day);
          daysContainer.appendChild(dayCell);
        }
      }

      function nextHourlyMonth() {
        event?.stopPropagation?.();
        hourlyCalendarState.currentMonth++;
        if (hourlyCalendarState.currentMonth > 11) {
          hourlyCalendarState.currentMonth = 0;
          hourlyCalendarState.currentYear++;
        }
        renderHourlyCalendar();
      }

      function prevHourlyMonth() {
        event?.stopPropagation?.();
        hourlyCalendarState.currentMonth--;
        if (hourlyCalendarState.currentMonth < 0) {
          hourlyCalendarState.currentMonth = 11;
          hourlyCalendarState.currentYear--;
        }
        renderHourlyCalendar();
      }

      function selectHourlyDate(day) {
        event?.stopPropagation?.();
        const month = String(hourlyCalendarState.currentMonth + 1).padStart(
          2,
          "0",
        );
        const date = String(day).padStart(2, "0");
        const year = hourlyCalendarState.currentYear;
        const selectedDate = `${month}/${date}/${year}`;

        if (hourlyCalendarState.selectedField === "start") {
          document.getElementById("hourlyStartDateInput").value = selectedDate;
        } else {
          document.getElementById("hourlyEndDateInput").value = selectedDate;
        }

        closeHourlyCalendar();
      }

      function applyHourlyDateFilter() {
        event?.stopPropagation?.();
        const startInput = document.getElementById(
          "hourlyStartDateInput",
        ).value;
        const endInput = document.getElementById("hourlyEndDateInput").value;

        if (startInput && startInput.length !== 10) {
          showToast("Invalid start date format");
          return;
        }
        if (endInput && endInput.length !== 10) {
          showToast("Invalid end date format");
          return;
        }

        window.hourlyStartDate = startInput
          ? parseHourlyDate(startInput)
          : null;
        window.hourlyEndDate = endInput ? parseHourlyDate(endInput) : null;

        filterHourlyTable();
        toggleHourlyDateFilter();
      }

      function clearHourlyDateFilter() {
        event?.stopPropagation?.();
        document.getElementById("hourlyStartDateInput").value = "";
        document.getElementById("hourlyEndDateInput").value = "";
        window.hourlyStartDate = null;
        window.hourlyEndDate = null;
        filterHourlyTable();
      }

      function parseHourlyDate(dateString) {
        if (!dateString || dateString.length !== 10) return null;
        const parts = dateString.split("/");
        if (parts.length !== 3) return null;
        return new Date(parts[2], parts[0] - 1, parts[1]);
      }

      function filterHourlyTable() {
        const startDate = window.hourlyStartDate || null;
        const endDate = window.hourlyEndDate || null;

        const tableRows = document.querySelectorAll(
          "#inlineHourlyTableBody tr",
        );

        tableRows.forEach((row) => {
          let shouldShow = true;
          if (startDate || endDate) {
            // Would need to parse date from row if you have one, for now show all
            shouldShow = true;
          }
          row.style.display = shouldShow ? "" : "none";
        });
      }

      // Export to CSV for hourly forecast
      function exportHourlyCSV() {
        event?.stopPropagation?.();
        const table = document.querySelector(
          "#inlineHourlyForecastSection .modern-table",
        );
        let csv = [];

        const headerCells = table.querySelectorAll("thead th");
        const headers = [];
        headerCells.forEach((th) => {
          headers.push(th.textContent.trim());
        });
        csv.push(headers.join(","));

        const rows = table.querySelectorAll("tbody tr");
        rows.forEach((row) => {
          const cells = row.querySelectorAll("td");
          const rowData = [];
          cells.forEach((cell) => {
            rowData.push(
              '"' + cell.textContent.trim().replace(/"/g, '""') + '"',
            );
          });
          csv.push(rowData.join(","));
        });

        downloadHourlyFile(csv.join("\n"), "hourly_forecast.csv");
      }

      // Export to Excel for hourly forecast
      function exportHourlyExcel() {
        event?.stopPropagation?.();
