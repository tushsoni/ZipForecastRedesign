        }

        // Update Increase/Decrease row $ prefix visibility
        const increasePrefixes = document.querySelectorAll(
          ".increase-decrease-prefix",
        );
        increasePrefixes.forEach((prefix) => {
          if (type === "sales") {
            prefix.style.display = "inline";
          } else {
            prefix.style.display = "none";
          }
        });

        // Update Increase/Decrease total cell format
        const increaseTotalCell = document.getElementById("increaseTotalCell");
        if (increaseTotalCell) {
          if (type === "sales") {
            increaseTotalCell.innerHTML =
              '$0<div class="text-[10px] text-slate-400 font-normal">0%</div>';
          } else if (type === "transactions") {
            increaseTotalCell.innerHTML =
              '0<div class="text-[10px] text-slate-400 font-normal">0%</div>';
          } else if (type === "labor") {
            increaseTotalCell.innerHTML =
              '0<div class="text-[10px] text-slate-400 font-normal">0%</div>';
          }
        }
      }

      // TOGGLE MY FORECAST AND INCREASE/DECREASE ROWS
      function toggleMyForecastRows() {
        const toggle = document.getElementById("enableMyForecastToggle");
        const myForecastRow = document.getElementById("myForecastRow");
        const increaseDecreaseRow = document.getElementById(
          "increaseDecreaseRow",
        );

        if (toggle.checked) {
          myForecastRow.classList.remove("hidden");
          increaseDecreaseRow.classList.remove("hidden");
        } else {
          myForecastRow.classList.add("hidden");
          increaseDecreaseRow.classList.add("hidden");
        }
      }

      // AI FORECAST POPUP FUNCTIONS
      function toggleAIFactorsPopup(event) {
        event.stopPropagation();
        const popup = document.getElementById("aiFactorsPopup");
        const button = event.target.closest("button");
        const rect = button.getBoundingClientRect();

        if (popup.style.display === "none" || popup.style.display === "") {
          popup.style.display = "block";
          popup.style.top = rect.bottom + 20 + "px";
          popup.style.left = rect.left + "px";
        } else {
          popup.style.display = "none";
        }

        lucide.createIcons();
      }

      // Close popup when clicking outside
      document.addEventListener("click", function (event) {
        const popup = document.getElementById("aiFactorsPopup");
        const button = document.querySelector(
          "[onclick*='toggleAIFactorsPopup']",
        );
        if (
          popup &&
          !popup.contains(event.target) &&
          !button.contains(event.target)
        ) {
          popup.style.display = "none";
        }
      });
    </script>
  </body>
</html>
