      function filterCateringByPeriod(period) {
        cateringSelectedPeriod = period;

        // Update button styles
        const buttons = ["7D", "14D", "1M"];
        buttons.forEach((btn) => {
          const element = document.getElementById(`toggle-${btn}`);
          if (btn === period) {
            element.className =
              "px-3 py-1.5 rounded-lg font-bold text-sm bg-blue-500 hover:bg-blue-600 text-white transition-all";
          } else {
            element.className =
              "px-3 py-1.5 rounded-lg font-bold text-sm bg-slate-200 hover:bg-slate-300 text-slate-700 transition-all";
          }
        });

        // Calculate date range based on period
        const now = new Date();
        let startDate = new Date();

        if (period === "7D") {
          startDate.setDate(now.getDate() - 7);
        } else if (period === "14D") {
          startDate.setDate(now.getDate() - 14);
        } else if (period === "1M") {
          startDate.setMonth(now.getMonth() - 1);
        }

        // Filter cateringData to show only records within the period
        const filteredData = cateringData.filter((item) => {
          const itemDate = new Date(item.datetime);
          return itemDate >= startDate && itemDate <= now;
        });

        // Update table with filtered data
        const body = document.getElementById("catering-table-body");
        if (!body) return;

        body.innerHTML = filteredData
          .map((item, index) => {
            // Find original index in cateringData for edit/delete functionality
