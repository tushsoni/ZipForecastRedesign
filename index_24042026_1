      // Parse Catering Date (MM/DD/YYYY format)
      function parseCateringDate(dateString) {
        if (!dateString || dateString.length !== 10) return null;
        const parts = dateString.split("/");
        if (parts.length !== 3) return null;
        return new Date(parts[2], parts[0] - 1, parts[1]);
      }

      // Main filter function for search and date range
      function filterCateringTable() {
        const searchTerm = document
          .getElementById("cateringSearch")
          .value.toLowerCase();
        const startDate = window.cateringStartDate || null;
        const endDate = window.cateringEndDate || null;

        const tableRows = document.querySelectorAll("#cateringTable tbody tr");

        tableRows.forEach((row) => {
          const searchData = row.getAttribute("data-search").toLowerCase();
          const itemDateTime = row.getAttribute("data-datetime");
          const itemDate = itemDateTime ? new Date(itemDateTime) : null;

          let matchesSearch = !searchTerm || searchData.includes(searchTerm);
          let matchesDateRange = true;

          if (startDate && itemDate) {
            matchesDateRange = itemDate >= startDate;
          }
          if (endDate && itemDate) {
            matchesDateRange = matchesDateRange && itemDate <= endDate;
          }

          row.style.display = matchesSearch && matchesDateRange ? "" : "none";
        });
      }

      // Export to CSV
      function exportCateringCSV() {
        const table = document.getElementById("cateringTable");
        let csv = [];

        const headerCells = table.querySelectorAll("thead th");
        const headers = [];
        headerCells.forEach((th) => {
          headers.push(th.textContent.trim());
        });
        csv.push(headers.join(","));

        const rows = table.querySelectorAll("tbody tr");
        rows.forEach((row) => {
          if (row.style.display !== "none") {
            const cells = [];
            row.querySelectorAll("td[data-column]").forEach((td) => {
              cells.push('"' + td.textContent.trim().replace(/"/g, '""') + '"');
            });
            csv.push(cells.join(","));
          }
        });

        downloadCateringFile(csv.join("\n"), "catering_data.csv");
      }

