      function setDateRange(chartId, range) {
        // Update button active state
        const buttons = document.querySelectorAll(`[data-chart="${chartId}"]`);
        buttons.forEach((btn) => btn.classList.remove("active"));
        document
          .querySelector(`[data-chart="${chartId}"][data-range="${range}"]`)
          .classList.add("active");

        // Update chart data based on chart type
        if (chartId === "projectionChart") {
          const metric = currentProjectionMetric || "sales";
          if (
            dateRangeData[chartId][range] &&
            dateRangeData[chartId][range][metric]
          ) {
            chartData[chartId].labels = dateRangeData[chartId][range].labels;
            chartData[chartId].datasets = dateRangeData[chartId][range][metric];
          }
          renderChart(chartId, "bar");
        } else if (chartId === "trendChart") {
          const trendType = currentTrendMetric || "transactions";
          if (
            dateRangeData[chartId][range] &&
            dateRangeData[chartId][range][trendType]
          ) {
            chartData[chartId].labels = dateRangeData[chartId][range].labels;
            chartData[chartId].datasets =
              dateRangeData[chartId][range][trendType];
          }
          renderChart(chartId, "bar");
        }

        // Refresh table if it's currently visible
        const tableContainer = document.getElementById(chartId + "-table");
        if (tableContainer && !tableContainer.classList.contains("hidden")) {
          renderInlineTable(chartId);
        }
      }

      function changeChartType(id, type) {
        // Hide table if visible
        const tableContainer = document.getElementById(id + "-table-container");
        if (tableContainer && !tableContainer.classList.contains("hidden")) {
          const canvas = document.getElementById(id);
          canvas.parentElement.classList.remove("hidden");
          tableContainer.classList.add("hidden");
          document.getElementById(id + "-table")?.classList.remove("active");
        }

        renderChart(id, type);
        ["line", "bar", "area"].forEach((t) =>
          document.getElementById(`${id}-${t}`)?.classList.remove("active"),
        );
        document.getElementById(`${id}-${type}`)?.classList.add("active");
      }

      function maximizeChart(id, title) {
        if (modalChartInstance) modalChartInstance.destroy();
        currentModalContext = null; // Clear context to avoid TypeError in render functions

        document.getElementById("modalTitle").innerText = title;
        document.getElementById("modalSubtitle").innerText = "";
        document.getElementById("chartModal").classList.add("active");
        document
          .getElementById("modalGraphContainer")
          .classList.remove("hidden");
        document.getElementById("modalTableContainer").classList.add("hidden");

        const ctx = document.getElementById("modalChart").getContext("2d");
        const source = charts[id];

        // Create a clean copy of the data
        modalChartInstance = new Chart(ctx, {
          type: source.config.type,
          data: JSON.parse(JSON.stringify(source.data)),
          options: {
            maintainAspectRatio: false,
            plugins: { legend: { display: true, position: "bottom" } },
          },
        });
      }

      // FIXED: This now ensures the buttons reappear when clicking on a KPI tile
      function openModal(title) {
        // Reset state and destroy previous instance
        if (modalChartInstance) modalChartInstance.destroy();

        currentModalContext = tileDataMap[title];
        if (!currentModalContext) return;

        // Show Graph and Table buttons for KPI tiles
        document.getElementById("modalOptions").style.display = "flex";
        document.getElementById("m-graph").style.display = "flex";
        document.getElementById("m-table").style.display = "flex";

        document
          .getElementById("modalGraphContainer")
          .classList.remove("hidden");
        document.getElementById("modalTableContainer").classList.add("hidden");
        document.getElementById("modalTitle").innerText = title;
        document.getElementById("chartModal").classList.add("active");

        updateModalView("graph");
        lucide.createIcons();
      }

      // FIXED: This helper now ensures the options are shown for specific graph tables
      function showChartTable(id, title) {
        // Clear tile context so it doesn't conflict
        currentModalContext = null;

        maximizeChart(id, title);

        // Show graph and table options for custom chart tables
        document.getElementById("modalOptions").style.display = "flex";
        document.getElementById("m-graph").style.display = "flex";
        document.getElementById("m-table").style.display = "flex";

        updateModalView("table");
      }

      function updateModalView(viewType) {
        const graphCont = document.getElementById("modalGraphContainer");
        const tableCont = document.getElementById("modalTableContainer");

        // Toggle Button Styles
        const btnGraph = document.getElementById("m-graph");
        const btnTable = document.getElementById("m-table");

        if (viewType === "graph") {
          btnGraph.className =
            "flex items-center gap-1.5 px-4 py-2 rounded-lg text-[13px] font-bold bg-blue-600 text-white shadow-md shadow-blue-200";
          btnTable.className =
            "flex items-center gap-1.5 px-4 py-2 rounded-lg text-[13px] font-bold text-slate-500 hover:text-slate-800 bg-transparent";
          graphCont.classList.remove("hidden");
          tableCont.classList.add("hidden");
          renderModalChart();
        } else if (viewType === "table") {
          btnTable.className =
            "flex items-center gap-1.5 px-4 py-2 rounded-lg text-[13px] font-bold bg-blue-600 text-white shadow-md shadow-blue-200";
          btnGraph.className =
            "flex items-center gap-1.5 px-4 py-2 rounded-lg text-[13px] font-bold text-slate-500 hover:text-slate-800 bg-transparent";
          graphCont.classList.add("hidden");
          tableCont.classList.remove("hidden");
          renderModalTable();
        }
      }

      function renderModalChart() {
        // FIX: Prevent TypeError if called without a KPI tile context
        if (!currentModalContext) return;

        const ctx = document.getElementById("modalChart").getContext("2d");
        if (modalChartInstance) modalChartInstance.destroy();

        // Always render as bar chart with three datasets for comparison
        const colors = {
          currentWeek: "#3b82f6",
          previousWeek: "#f59e0b",
          lastYear: "#10b981",
        };

        modalChartInstance = new Chart(ctx, {
          type: "bar",
          data: {
            labels: currentModalContext.dates,
            datasets: [
              {
                label: "Current Week",
                data: currentModalContext.currentWeek,
                backgroundColor: colors.currentWeek,
                borderRadius: 6,
              },
              {
                label: "Previous Week",
                data: currentModalContext.previousWeek,
                backgroundColor: colors.previousWeek,
                borderRadius: 6,
              },
              {
                label: "Last Year",
                data: currentModalContext.lastYear,
                backgroundColor: colors.lastYear,
                borderRadius: 6,
              },
            ],
          },
          options: {
            maintainAspectRatio: false,
            plugins: {
              legend: {
                display: true,
                position: "bottom",
                align: "center",
                labels: {
                  boxWidth: 14,
                  padding: 25,
